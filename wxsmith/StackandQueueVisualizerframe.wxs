<?xml version="1.0" encoding="utf-8" ?>
<wxsmith>
	<object class="wxFrame" name="StackandQueueVisualizerFrame">
		<title>Samantha&apos;s Stack and Queue Visualizer</title>
		<centered>1</centered>
		<size>800,500</size>
		<id_arg>0</id_arg>
		<object class="wxNotebook" name="ID_NOTEBOOK1" variable="Notebook1" member="yes">
			<pos>512,360</pos>
			<object class="notebookpage">
				<object class="wxPanel" name="ID_PANEL1" variable="StackPanel" member="yes">
					<pos>-1,-1</pos>
					<minsize>-1,-1</minsize>
					<maxsize>-1,-1</maxsize>
					<object class="wxBoxSizer" variable="BoxSizer1" member="yes">
						<orient>wxVERTICAL</orient>
						<object class="sizeritem">
							<object class="wxStaticText" name="ID_STATICTEXT1" variable="StackLabel" member="yes">
								<label> STACK (LIFO - Last In First Out) &#x0A;**To add an integer to the stack :  Enter the number then select Push**&#x0A;**To remove an integer from the stack: select Pop**</label>
								<size>790,85</size>
							</object>
							<flag>wxALL|wxSHAPED</flag>
							<border>1</border>
							<option>1</option>
						</object>
						<object class="sizeritem">
							<object class="wxBoxSizer" variable="BoxSizer2" member="no">
								<object class="sizeritem">
									<object class="wxStaticText" name="ID_STATICTEXT2" variable="Value" member="yes">
										<label>      Enter an integer:</label>
										<size>56,26</size>
									</object>
									<flag>wxALL|wxEXPAND</flag>
									<border>5</border>
									<option>1</option>
								</object>
								<object class="sizeritem">
									<object class="wxTextCtrl" name="ID_TEXTCTRL1" variable="TextCtrl1" member="yes" />
									<flag>wxALL|wxALIGN_CENTER_HORIZONTAL|wxALIGN_CENTER_VERTICAL</flag>
									<border>5</border>
									<option>1</option>
								</object>
								<object class="sizeritem">
									<object class="wxButton" name="ID_BUTTON1" variable="pushButton" member="yes">
										<label>Push</label>
										<handler function="OnpushButtonClick" entry="EVT_BUTTON" />
									</object>
									<flag>wxALL</flag>
									<border>5</border>
									<option>1</option>
								</object>
								<object class="sizeritem">
									<object class="wxButton" name="ID_BUTTON2" variable="popButton" member="yes">
										<label>Pop</label>
										<handler function="OnpopButtonClick" entry="EVT_BUTTON" />
									</object>
									<flag>wxALL|wxALIGN_CENTER_HORIZONTAL|wxALIGN_CENTER_VERTICAL</flag>
									<border>5</border>
									<option>1</option>
								</object>
							</object>
							<flag>wxALL|wxSHAPED</flag>
							<border>5</border>
							<option>1</option>
						</object>
						<object class="sizeritem">
							<object class="wxListBox" name="ID_LISTBOX1" variable="StackList" member="yes">
								<default>-1</default>
								<size>782,306</size>
							</object>
							<flag>wxALL|wxEXPAND</flag>
							<border>5</border>
							<option>1</option>
						</object>
					</object>
				</object>
				<label>Stack</label>
			</object>
			<object class="notebookpage">
				<object class="wxPanel" name="ID_PANEL2" variable="QueuePanel" member="yes">
					<object class="wxBoxSizer" variable="BoxSizer3" member="no">
						<orient>wxVERTICAL</orient>
						<object class="sizeritem">
							<object class="wxStaticText" name="ID_STATICTEXT3" variable="QueueLabel" member="yes">
								<label> QUEUE (FIFO - First In First Out) &#x0A;**To add an integer to the queue :  Enter the number then select Enqueue**&#x0A;**To remove an integer from the queue: select Dequeue**</label>
								<size>790,82</size>
							</object>
							<flag>wxALL|wxSHAPED</flag>
							<border>-1</border>
							<option>1</option>
						</object>
						<object class="sizeritem">
							<object class="wxBoxSizer" variable="BoxSizer4" member="no">
								<object class="sizeritem">
									<object class="wxStaticText" name="ID_STATICTEXT4" variable="Value2" member="yes">
										<label>     Enter an integer:</label>
										<size>56,26</size>
									</object>
									<flag>wxALL|wxEXPAND</flag>
									<border>5</border>
									<option>1</option>
								</object>
								<object class="sizeritem">
									<object class="wxTextCtrl" name="ID_TEXTCTRL2" variable="TextCtrl2" member="yes" />
									<flag>wxALL|wxEXPAND</flag>
									<border>5</border>
									<option>1</option>
								</object>
								<object class="sizeritem">
									<object class="wxButton" name="ID_BUTTON3" variable="queueButton" member="yes">
										<label>Enqueue</label>
										<handler function="OnqueueButtonClick" entry="EVT_BUTTON" />
									</object>
									<flag>wxALL|wxALIGN_CENTER_HORIZONTAL|wxALIGN_CENTER_VERTICAL</flag>
									<border>5</border>
									<option>1</option>
								</object>
								<object class="sizeritem">
									<object class="wxButton" name="ID_BUTTON4" variable="dequeueButton" member="yes">
										<label>Dequeue</label>
										<handler function="OndequeueButtonClick" entry="EVT_BUTTON" />
									</object>
									<flag>wxALL|wxALIGN_CENTER_HORIZONTAL|wxALIGN_CENTER_VERTICAL</flag>
									<border>5</border>
									<option>1</option>
								</object>
							</object>
							<flag>wxALL|wxSHAPED</flag>
							<border>5</border>
							<option>1</option>
						</object>
						<object class="sizeritem">
							<object class="wxListBox" name="ID_LISTBOX2" variable="QueueList" member="yes">
								<default>-1</default>
								<size>782,306</size>
							</object>
							<flag>wxALL|wxEXPAND</flag>
							<border>5</border>
							<option>1</option>
						</object>
					</object>
				</object>
				<label>Queue</label>
			</object>
		</object>
		<object class="wxMenuBar" variable="MenuBar1" member="no">
			<object class="wxMenu" variable="Menu1" member="no">
				<label>&amp;File</label>
				<object class="wxMenuItem" name="ID_MENUITEM1" variable="MenuItem1" member="no">
					<label>Quit</label>
					<accel>Alt-F4</accel>
					<help>Quit the application</help>
					<handler function="OnQuit" entry="EVT_MENU" />
				</object>
			</object>
			<object class="wxMenu" variable="Menu2" member="no">
				<label>Help</label>
				<object class="wxMenuItem" name="idMenuAbout" variable="MenuItem2" member="no">
					<label>About</label>
					<accel>F1</accel>
					<help>Show info about this application</help>
					<handler function="OnAbout" entry="EVT_MENU" />
				</object>
			</object>
		</object>
		<object class="wxStatusBar" name="ID_STATUSBAR1" variable="StatusBar1" member="yes">
			<fields>1</fields>
			<widths>-1</widths>
			<styles>wxSB_NORMAL</styles>
		</object>
	</object>
</wxsmith>
